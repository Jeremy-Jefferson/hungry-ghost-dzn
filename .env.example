# ========================================
# Hungry Ghost DZN - Environment Variables
# ========================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# ----------------------------
# Server Configuration
# ----------------------------
PORT=5000
NODE_ENV=development

# ----------------------------
# Client Configuration
# ----------------------------
# The origin URL for CORS (e.g., http://localhost:5173 for dev, https://yourdomain.com for prod)
CLIENT_ORIGIN=http://localhost:5173

# ----------------------------
# Email / SMTP Configuration
# ----------------------------
# Required for production email sending
# If not set, the contact form will use a mock transporter
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM="Hungry Ghost DZN" <noreply@hungryghost.design>

# ----------------------------
# Contact Form
# ----------------------------
# Email address to receive contact form submissions
CONTACT_EMAIL=therealhungryghost@gmail.com

# ========================================
# Production Deployment Checklist
# ========================================
# 1. Set NODE_ENV=production
# 2. Update CLIENT_ORIGIN to your production URL
# 3. Configure SMTP credentials for email sending
# 4. Update sitemap hostname in vite.config.js
# 5. Update canonical URLs in index.html
# 6. Build client: cd client && npm run build
# 7. Start server: cd server && npm start
