{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
"installCommand":"cd client && npm install",
"buildCommand":"cd client && npm run build",
  "outputDirectory": "client/dist",
"devCommand":"cd client && pnpm run dev",
    "functions": {
      "api/contact.js": {
        "maxDuration": 10
      }
    },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}